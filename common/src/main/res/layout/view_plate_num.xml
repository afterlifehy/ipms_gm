<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_plate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@mipmap/ic_plate_blue_bg_start"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/sp_27"
        android:textStyle="bold"
        tools:text="沪" />

    <com.aries.ui.view.radius.RadiusFrameLayout
        android:id="@+id/rfl_stroke"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:rv_backgroundColor="@color/transparent"
        app:rv_strokeColor="@color/color_fff71c1c"
        app:rv_strokeWidth="@dimen/dp_3" />
</FrameLayout>
